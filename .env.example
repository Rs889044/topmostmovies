# Copy to .env (git-ignored) and fill in. NEVER commit real keys.
# See docs/DATA-SOURCES.md.

# --- TMDb (primary data source) ---
# Get a key/token at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_READ_TOKEN=            # optional v4 read access token (alternative to TMDB_API_KEY)

# --- OMDb (supplementary: IMDb rating number) ---
# Get a key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# --- Site ---
PUBLIC_SITE_URL=https://topmostmovies.com
PUBLIC_CONTACT_EMAIL=hello@topmostmovies.com   # shown on contact/privacy pages

# --- Monetization / analytics (no live code until these are set; ads/analytics also
#     require user consent at runtime). See docs/OPERATIONS.md for how to obtain each. ---
# PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX  # AdSense publisher id (enables ads.txt, ad units, verification meta)
# PUBLIC_GA_ID=G-XXXXXXXXXX                       # GA4 Measurement ID (enables page tracking)
