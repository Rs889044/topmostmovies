# Secrets — never commit
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Astro build output & cache
dist/
.astro/

# Build-time API response cache (raw, re-fetchable). The normalized src/data/*.json
# dataset IS committed for reproducible builds (see docs/ARCHITECTURE.md open question).
.cache/

# Agent skills — installed via `npx skills add`; re-installable from skills-lock.json
# (committed). Skill bodies are third-party, treated like node_modules.
.agents/

# OS / editor
.DS_Store
*.log
npm-debug.log*
.vscode/*
!.vscode/extensions.json
.idea/
