# Cloudflare Pages headers. Applies on deploy. See docs/OPERATIONS.md.

# Long-cache immutable, content-hashed build assets (safe — filenames change on rebuild).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Optimized images emitted by Astro are also content-hashed.
/_image*
  Cache-Control: public, max-age=31536000, immutable

# Security + good-practice headers for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# NOTE: Duplicate content from the *.pages.dev preview is handled by (a) every page's
# canonical pointing to the .com, and (b) preview deployments being disabled on the
# Cloudflare Pages project (Settings → Build → preview branch: None). A static _headers
# file can't target the preview host only, so we don't use X-Robots-Tag here.
