# Cloudflare Pages headers. Applies on deploy. See docs/OPERATIONS.md.

# Long-cache immutable, content-hashed build assets (safe — filenames change on rebuild).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Optimized images emitted by Astro are also content-hashed.
/_image*
  Cache-Control: public, max-age=31536000, immutable

# Security + good-practice headers for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# NOTE: The *.pages.dev preview URL is kept out of Google's index to avoid duplicate
# content. A static _headers file can't target the preview host only, so this is done
# with a Cloudflare Pages "Transform Rule" that adds `X-Robots-Tag: noindex` when the
# Host ends in `.pages.dev`. Steps are in docs/OPERATIONS.md (Phase 8).
