---
/**
 * AdSlot.astro — reserved-space ad placeholder (dark theme). Renders ONLY a fixed-height
 * placeholder until an AdSense publisher ID is provided (PUBLIC_ADSENSE_CLIENT) — no live
 * ad code yet. Reserved height prevents layout shift (CLS). See docs/ADSENSE.md.
 */
export interface Props {
  slot: string;
  class?: string;
  minHeight?: number;
}

const { slot, class: className = '', minHeight = 100 } = Astro.props;

const ADSENSE_CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const live = Boolean(ADSENSE_CLIENT);
---

<aside
  class:list={['ad-slot flex items-center justify-center', className]}
  style={`min-height:${minHeight}px`}
  data-ad-slot={slot}
  aria-hidden="true"
>
  {
    live ? (
      <div class="w-full" data-adsense-placeholder={ADSENSE_CLIENT} />
    ) : (
      <div class="w-full rounded-lg border border-dashed border-ink-700 py-6 text-center text-xs uppercase tracking-widest text-ink-600">
        Advertisement
      </div>
    )
  }
</aside>
