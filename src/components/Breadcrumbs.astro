---
/**
 * Breadcrumbs.astro — visible breadcrumb trail for interior pages (dark theme).
 * Emit matching BreadcrumbList JSON-LD via <Seo jsonLd={breadcrumbList(...)} />.
 */
import type { Crumb } from '../lib/jsonld';

export interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-fg-subtle">
  <ol class="flex flex-wrap items-center gap-1.5">
    {
      crumbs.map((c, i) => {
        const isLast = i === crumbs.length - 1;
        return (
          <li class="flex items-center gap-1.5">
            {isLast ? (
              <span aria-current="page" class="text-fg-muted">
                {c.name}
              </span>
            ) : (
              <a href={c.path} class="hover:text-accent-400">
                {c.name}
              </a>
            )}
            {!isLast && <span aria-hidden="true" class="text-ink-600">/</span>}
          </li>
        );
      })
    }
  </ol>
</nav>
