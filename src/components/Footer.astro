---
/**
 * Footer.astro — dark site footer.
 * REQUIRED: TMDb attribution on every page (see docs/DATA-SOURCES.md). Do not remove.
 */
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-ink-700/60 bg-ink-900">
  <div class="container-page py-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <Logo size="sm" />
        <p class="mt-2 max-w-xs text-sm text-fg-subtle">
          Curated Top 10 movie lists with honest ratings and parental info.
        </p>
      </div>

      <div class="flex flex-col gap-6 sm:flex-row sm:gap-12">
        <nav aria-label="Browse" class="flex flex-col gap-2 text-sm">
          <span class="font-semibold text-fg-subtle">Browse</span>
          <a href="/best-movies" class="text-fg-muted hover:text-accent-400">Greatest of all time</a>
          <a href="/popular" class="text-fg-muted hover:text-accent-400">Most popular</a>
          <a href="/genre" class="text-fg-muted hover:text-accent-400">Genres</a>
          <a href="/studio" class="text-fg-muted hover:text-accent-400">Studios</a>
          <a href="/theme" class="text-fg-muted hover:text-accent-400">Themes</a>
          <a href="/decade" class="text-fg-muted hover:text-accent-400">Decades</a>
          <a href="/blog" class="text-fg-muted hover:text-accent-400">Blog</a>
        </nav>
        <nav aria-label="Site" class="flex flex-col gap-2 text-sm">
          <span class="font-semibold text-fg-subtle">Site</span>
          <a href="/about" class="text-fg-muted hover:text-accent-400">About</a>
          <a href="/contact" class="text-fg-muted hover:text-accent-400">Contact</a>
          <a href="/privacy-policy" class="text-fg-muted hover:text-accent-400">Privacy Policy</a>
          <a href="/cookie-policy" class="text-fg-muted hover:text-accent-400">Cookie Policy</a>
          <a href="#" data-cookie-settings class="text-fg-muted hover:text-accent-400">Cookie settings</a>
        </nav>
      </div>
    </div>

    {/* TMDb attribution — required by the TMDb API terms. */}
    <div class="mt-8 border-t border-ink-800 pt-6 text-xs leading-relaxed text-fg-subtle">
      <p class="max-w-prose">
        This product uses the TMDb API but is not endorsed or certified by TMDb. Movie data
        and images are provided by The Movie Database (TMDb); IMDb ratings are sourced via
        the OMDb API.
      </p>
      <p class="mt-3">&copy; {year} topmostmovies.com</p>
    </div>
  </div>
</footer>
