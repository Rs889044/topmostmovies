---
/**
 * Footer.astro — dark site footer.
 * REQUIRED: TMDb attribution on every page (see docs/DATA-SOURCES.md). Do not remove.
 */
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-ink-700/60 bg-ink-900">
  <div class="container-page py-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
          <span
            class="inline-flex h-6 w-6 items-center justify-center rounded bg-accent-500 text-xs font-black text-ink-950"
            aria-hidden="true">★</span
          >
          <span class="text-fg">topmost<span class="text-accent-500">movies</span></span>
        </a>
        <p class="mt-2 max-w-xs text-sm text-fg-subtle">
          Curated Top 10 movie lists with honest ratings and parental info.
        </p>
      </div>

      <nav aria-label="Footer" class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        <a href="/about" class="text-fg-muted hover:text-accent-400">About</a>
        <a href="/contact" class="text-fg-muted hover:text-accent-400">Contact</a>
        <a href="/privacy-policy" class="text-fg-muted hover:text-accent-400">Privacy Policy</a>
      </nav>
    </div>

    {/* TMDb attribution — required by the TMDb API terms. */}
    <div class="mt-8 border-t border-ink-800 pt-6 text-xs leading-relaxed text-fg-subtle">
      <p class="max-w-prose">
        This product uses the TMDb API but is not endorsed or certified by TMDb. Movie data
        and images are provided by The Movie Database (TMDb); IMDb ratings are sourced via
        the OMDb API.
      </p>
      <p class="mt-3">&copy; {year} topmostmovies.com</p>
    </div>
  </div>
</footer>
