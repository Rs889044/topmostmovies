---
/**
 * Footer.astro — site footer.
 * REQUIRED: TMDb attribution on every page (see docs/DATA-SOURCES.md). Do not remove.
 */
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-gray-200 bg-gray-50">
  <div class="mx-auto max-w-5xl space-y-4 px-4 py-8 text-sm text-gray-500">
    <nav aria-label="Footer" class="flex flex-wrap gap-x-4 gap-y-2">
      <a href="/about" class="hover:text-brand-700 hover:underline">About</a>
      <a href="/contact" class="hover:text-brand-700 hover:underline">Contact</a>
      <a href="/privacy-policy" class="hover:text-brand-700 hover:underline">Privacy Policy</a>
    </nav>

    {/* TMDb attribution — required by the TMDb API terms. */}
    <p class="max-w-prose text-xs leading-relaxed text-gray-400">
      This product uses the TMDb API but is not endorsed or certified by TMDb. Movie data
      and images are provided by The Movie Database (TMDb); IMDb ratings are sourced via
      the OMDb API.
    </p>

    <p class="text-xs text-gray-400">&copy; {year} topmostmovies.com</p>
  </div>
</footer>
