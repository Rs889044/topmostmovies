---
/**
 * Header.astro — sticky dark site header + primary navigation.
 * Nav points to the dimension HUB/index pages (e.g. /genre lists every genre), which are
 * real destinations rather than arbitrary single lists.
 */
import Logo from './Logo.astro';

const nav = [
  { label: 'Genres', href: '/genre' },
  { label: 'Studios', href: '/studio' },
  { label: 'Themes', href: '/theme' },
  { label: 'Countries', href: '/country' },
  { label: 'Languages', href: '/language' },
  { label: 'Decades', href: '/decade' },
];
---

<header
  class="sticky top-0 z-50 border-b border-ink-700/60 bg-ink-950/80 backdrop-blur-md"
>
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <Logo size="md" />

    <nav
      aria-label="Primary"
      class="hidden items-center gap-1 text-sm font-medium md:flex"
    >
      {
        nav.map((d) => (
          <a
            href={d.href}
            class="rounded-md px-3 py-2 text-fg-muted transition-colors hover:bg-ink-800 hover:text-fg"
          >
            {d.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
