---
/**
 * Header.astro — sticky dark site header + primary navigation.
 * Nav points to a representative POPULATED list per dimension (from real data) so links
 * never 404.
 */
import { allMovies } from '../lib/movies';
import { buildList, enumerateLists } from '../lib/lists';
import type { Dimension } from '../lib/taxonomy';

const movies = await allMovies();
const refs = await enumerateLists();

const pathBase: Record<Dimension, string> = {
  industry: 'industry',
  country: 'country',
  language: 'language',
  genre: 'genre',
  year: 'year',
  decade: 'decade',
};

function topLink(dimension: Dimension): string {
  const best = refs
    .filter((r) => r.dimension === dimension)
    .map((r) => ({ r, count: buildList(movies, dimension, r.value).total }))
    .sort((a, b) => b.count - a.count)[0];
  return best ? `/${pathBase[dimension]}/${best.r.value}` : '/';
}

const dimensions: { label: string; dimension: Dimension }[] = [
  { label: 'Genres', dimension: 'genre' },
  { label: 'Countries', dimension: 'country' },
  { label: 'Languages', dimension: 'language' },
  { label: 'Industries', dimension: 'industry' },
  { label: 'Decades', dimension: 'decade' },
];
const nav = dimensions.map((d) => ({ label: d.label, href: topLink(d.dimension) }));
---

<header
  class="sticky top-0 z-50 border-b border-ink-700/60 bg-ink-950/80 backdrop-blur-md"
>
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
      <span
        class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-accent-500 text-sm font-black text-ink-950"
        aria-hidden="true">★</span
      >
      <span class="text-lg text-fg">topmost<span class="text-accent-500">movies</span></span>
    </a>

    <nav
      aria-label="Primary"
      class="hidden items-center gap-1 text-sm font-medium md:flex"
    >
      {
        nav.map((d) => (
          <a
            href={d.href}
            class="rounded-md px-3 py-2 text-fg-muted transition-colors hover:bg-ink-800 hover:text-fg"
          >
            {d.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
