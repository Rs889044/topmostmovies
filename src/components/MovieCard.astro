---
/**
 * MovieCard.astro — poster-forward card for list/grid pages. Poster with gradient overlay,
 * rank badge, rating chip, certification, title + year, and an optional per-list blurb.
 * Reserves the 2:3 poster aspect ratio to avoid CLS. See docs/SEO.md.
 */
import { Image } from 'astro:assets';
import type { MovieData } from '../lib/movies';

export interface Props {
  movie: MovieData;
  rank?: number;
  blurb?: string;
  /** Prioritize loading (above-the-fold LCP candidate). */
  priority?: boolean;
}

const { movie, rank, blurb, priority = false } = Astro.props;
const rating = movie.imdbRating ?? movie.tmdbRating;
const ratingSource = movie.imdbRating ? 'IMDb' : movie.tmdbRating ? 'TMDb' : undefined;
---

<article class="group relative flex flex-col">
  <a
    href={`/movie/${movie.slug}`}
    class="relative block overflow-hidden rounded-xl bg-ink-800 ring-1 ring-ink-700/60 transition duration-300 group-hover:ring-accent-500/60"
  >
    <div class="relative aspect-[2/3] w-full">
      {
        movie.posterUrl ? (
          <Image
            src={movie.posterUrl}
            alt={movie.posterAlt}
            width={300}
            height={450}
            loading={priority ? 'eager' : 'lazy'}
            class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04]"
            inferSize={false}
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-xs text-fg-subtle">
            No poster
          </div>
        )
      }

      {/* Gradient for chip/legibility */}
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-ink-950/90 to-transparent"
        aria-hidden="true"
      >
      </div>

      {/* Rank badge */}
      {
        rank !== undefined && (
          <span class="absolute left-2 top-2 inline-flex h-7 min-w-7 items-center justify-center rounded-lg bg-ink-950/80 px-1.5 text-sm font-bold tabular-nums text-accent-400 backdrop-blur-sm">
            {rank}
          </span>
        )
      }

      {/* Rating chip */}
      {
        rating !== undefined && (
          <span class="absolute bottom-2 left-2 inline-flex items-center gap-1 rounded-md bg-ink-950/80 px-1.5 py-0.5 text-xs font-semibold text-fg backdrop-blur-sm">
            <span class="text-star" aria-hidden="true">
              ★
            </span>
            {rating.toFixed(1)}
            <span class="font-normal text-fg-subtle">{ratingSource}</span>
          </span>
        )
      }

      {/* Certification chip */}
      {
        movie.certification && (
          <span class="absolute bottom-2 right-2 rounded-md border border-ink-600 bg-ink-950/80 px-1.5 py-0.5 text-[10px] font-medium text-fg-muted backdrop-blur-sm">
            {movie.certification}
          </span>
        )
      }
    </div>
  </a>

  <div class="mt-2.5 min-w-0">
    <h3 class="truncate text-sm font-semibold text-fg">
      <a href={`/movie/${movie.slug}`} class="hover:text-accent-400">
        {movie.title}
      </a>
    </h3>
    <p class="text-xs text-fg-subtle">{movie.year}</p>
    {blurb && <p class="mt-1.5 line-clamp-3 text-xs leading-relaxed text-fg-muted">{blurb}</p>}
  </div>
</article>
