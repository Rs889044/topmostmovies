---
/**
 * MovieRow.astro — a titled, horizontally-scrolling strip of movie posters for the
 * homepage's curated rows. Links the heading to the full list page.
 */
import { Image } from 'astro:assets';
import type { MovieData } from '../lib/movies';

export interface Props {
  title: string;
  href: string;
  movies: MovieData[];
}

const { title, href, movies } = Astro.props;
---

{
  movies.length > 0 && (
    <section class="mt-8 first:mt-10">
      <div class="container-page mb-4 flex items-baseline justify-between">
        <h2 class="text-xl font-bold sm:text-2xl">{title}</h2>
        <a href={href} class="shrink-0 text-sm font-medium text-accent-400 hover:text-accent-300">
          View all →
        </a>
      </div>
      <ul class="container-page flex snap-x gap-4 overflow-x-auto pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {movies.map((movie) => (
          <li class="w-32 shrink-0 snap-start sm:w-36">
            <a
              href={`/movie/${movie.slug}`}
              class="group block overflow-hidden rounded-lg bg-ink-800 ring-1 ring-ink-700/60 transition hover:ring-accent-500/60"
            >
              <div class="relative aspect-[2/3]">
                {movie.posterUrl ? (
                  <Image
                    src={movie.posterUrl}
                    alt={movie.posterAlt}
                    width={144}
                    height={216}
                    loading="lazy"
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                    inferSize={false}
                  />
                ) : (
                  <div class="flex h-full items-center justify-center text-xs text-fg-subtle">
                    No poster
                  </div>
                )}
                {(movie.imdbRating ?? movie.tmdbRating) !== undefined && (
                  <span class="absolute bottom-1.5 left-1.5 inline-flex items-center gap-1 rounded bg-ink-950/80 px-1.5 py-0.5 text-xs font-semibold backdrop-blur-sm">
                    <span class="text-star" aria-hidden="true">★</span>
                    {(movie.imdbRating ?? movie.tmdbRating)!.toFixed(1)}
                  </span>
                )}
              </div>
            </a>
            <p class="mt-1.5 truncate text-xs font-medium text-fg-muted">{movie.title}</p>
          </li>
        ))}
      </ul>
    </section>
  )
}
