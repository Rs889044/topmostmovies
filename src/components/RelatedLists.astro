---
/**
 * RelatedLists.astro — internal-linking block of related "Top 10 …" lists shown on list
 * pages. Strengthens topical internal linking for long-tail SEO. See docs/SEO.md.
 */
import type { RelatedLink } from '../lib/lists';

export interface Props {
  links: RelatedLink[];
  heading?: string;
}

const { links, heading = 'Explore related lists' } = Astro.props;
---

{
  links.length > 0 && (
    <nav aria-labelledby="related-heading" class="mt-10">
      <h2 id="related-heading" class="mb-3 text-xl font-semibold">{heading}</h2>
      <ul class="flex flex-wrap gap-2">
        {links.map((l) => (
          <li>
            <a
              href={l.path}
              class="inline-block rounded-full border border-gray-200 px-3 py-1 text-sm text-gray-700 hover:border-brand-500 hover:text-brand-700"
            >
              {l.name}
              <span class="text-gray-400"> ({l.count})</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
