---
/**
 * RelatedLists.astro — internal-linking block of related "Top 10 …" lists (dark theme).
 * Strengthens topical internal linking for long-tail SEO. See docs/SEO.md.
 */
import type { RelatedLink } from '../lib/lists';

export interface Props {
  links: RelatedLink[];
  heading?: string;
}

const { links, heading = 'Explore related lists' } = Astro.props;
---

{
  links.length > 0 && (
    <nav aria-labelledby="related-heading" class="mt-12">
      <h2 id="related-heading" class="mb-4 text-2xl font-bold">{heading}</h2>
      <ul class="flex flex-wrap gap-2">
        {links.map((l) => (
          <li>
            <a
              href={l.path}
              class="inline-flex items-center gap-1.5 rounded-full border border-ink-600 bg-ink-800 px-3.5 py-1.5 text-sm text-fg-muted transition-colors hover:border-accent-500/60 hover:text-fg"
            >
              {l.name}
              <span class="text-fg-subtle">{l.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
