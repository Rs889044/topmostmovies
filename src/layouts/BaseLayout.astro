---
/**
 * BaseLayout.astro — the HTML shell every page uses.
 * Wires global styles, <Seo>, Header, Footer. Page content goes in the default slot;
 * extra <head> content (e.g. preloads) can go in the "head" slot.
 * CookieConsent banner is mounted here in Phase 6.
 */
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Props as SeoProps } from '../components/Seo.astro';

export interface Props {
  seo: SeoProps;
}

const { seo } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <Seo {...seo} />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col bg-white text-gray-900 antialiased">
    <Header />
    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
