---
/**
 * BaseLayout.astro — the HTML shell every page uses.
 * Wires global styles, <Seo>, Header, Footer. Page content goes in the default slot;
 * extra <head> content (e.g. preloads) can go in the "head" slot.
 * CookieConsent banner is mounted here in Phase 6.
 */
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Props as SeoProps } from '../components/Seo.astro';

export interface Props {
  seo: SeoProps;
}

const { seo } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#07090d" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* Speed up first poster load (LCP). */}
    <link rel="preconnect" href="https://image.tmdb.org" crossorigin />
    {/* Inter font, swap to avoid invisible text (WIG perf). */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <Seo {...seo} />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col bg-ink-950 text-fg antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
