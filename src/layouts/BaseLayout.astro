---
/**
 * BaseLayout.astro — the HTML shell every page uses.
 * Wires global styles, <Seo>, Header, Footer. Page content goes in the default slot;
 * extra <head> content (e.g. preloads) can go in the "head" slot.
 * CookieConsent banner is mounted here in Phase 6.
 */
import '../styles/global.css';
// Resolve the hashed URL of the latin Inter woff2 so we can preload it (English needs only
// this subset). Preloading prevents the font-swap layout shift on big hero text (CLS).
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Analytics from '../components/Analytics.astro';
import AdSenseLoader from '../components/AdSenseLoader.astro';
import type { Props as SeoProps } from '../components/Seo.astro';

export interface Props {
  seo: SeoProps;
}

const { seo } = Astro.props;
const ADSENSE_CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#07090d" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* Speed up first poster load (LCP). Inter is self-hosted (bundled) — no font CDN. */}
    <link rel="preconnect" href="https://image.tmdb.org" crossorigin />
    {/* Preload the latin Inter subset so hero text renders in Inter immediately (no swap → no CLS). */}
    <link rel="preload" href={interLatin} as="font" type="font/woff2" crossorigin />
    {/* AdSense site-verification meta (only when a publisher ID is configured). */}
    {ADSENSE_CLIENT && <meta name="google-adsense-account" content={ADSENSE_CLIENT} />}
    <Seo {...seo} />
    <slot name="head" />
    {/* Gated loaders: render nothing unless their ID is set + consent granted. */}
    <Analytics />
    <AdSenseLoader />
  </head>
  <body class="flex min-h-screen flex-col bg-ink-950 text-fg antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[200] focus:rounded-lg focus:bg-accent-500 focus:px-4 focus:py-2 focus:font-semibold focus:text-ink-950"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
