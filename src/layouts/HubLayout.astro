---
/**
 * HubLayout.astro — dimension index/hub page (e.g. /genre lists every genre). Each card
 * links to that value's "Top 10 …" list. Strengthens internal linking + gives the header
 * nav a real destination. Renders Breadcrumb + CollectionPage JSON-LD.
 */
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { HubEntry } from '../lib/lists';
import { breadcrumbList, collectionPage, type Crumb } from '../lib/jsonld';

export interface Props {
  title: string; // e.g. "Browse Movies by Genre"
  basePath: string; // e.g. "/genre"
  label: string; // e.g. "Genres"
  intro: string;
  entries: HubEntry[];
}

const { title, basePath, label, intro, entries } = Astro.props;
const site = Astro.site ?? new URL('https://topmostmovies.com');

const crumbs: Crumb[] = [
  { name: 'Home', path: '/' },
  { name: label, path: basePath },
];

const jsonLd = [
  breadcrumbList(crumbs, site),
  collectionPage(
    title,
    basePath,
    entries.map((e) => ({ name: e.name, path: e.path })),
    site,
  ),
];

const seo = {
  title: `${title} — topmostmovies.com`,
  description: intro.slice(0, 160),
  ogType: 'website' as const,
  image: entries.find((e) => e.posterUrl)?.posterUrl,
  jsonLd,
};
---

<BaseLayout seo={seo}>
  <section class="border-b border-ink-700/60">
    <div class="container-page py-10 sm:py-14">
      <Breadcrumbs crumbs={crumbs} />
      <h1 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-5xl">{title}</h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-fg-muted sm:text-lg">{intro}</p>
      <p class="mt-3 text-sm text-fg-subtle">{entries.length} {label.toLowerCase()}</p>
    </div>
  </section>

  <div class="container-page py-8">
    <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {
        entries.map((e) => (
          <li>
            <a
              href={e.path}
              class="group block overflow-hidden rounded-xl border border-ink-700/60 bg-ink-900 transition hover:border-accent-500/60"
            >
              <div class="relative aspect-video overflow-hidden bg-ink-800">
                {e.posterUrl ? (
                  <Image
                    src={e.posterUrl}
                    alt=""
                    width={300}
                    height={169}
                    loading="lazy"
                    class="h-full w-full object-cover object-top opacity-60 transition duration-500 group-hover:scale-105 group-hover:opacity-80"
                    inferSize={false}
                  />
                ) : null}
                <div class="absolute inset-0 bg-gradient-to-t from-ink-950/90 to-transparent" />
              </div>
              <div class="flex items-center justify-between gap-2 px-4 py-3">
                <span class="font-semibold text-fg group-hover:text-accent-400">{e.name}</span>
                <span class="text-sm text-fg-subtle">{e.count}</span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
