---
/**
 * ListLayout.astro — shared "Top 10 …" list page. Used by all six dimension routes.
 * Renders breadcrumbs, h1 + intro, ranked MovieCards (with per-list blurbs), an optional
 * FAQ block, and ad slots. Wires ItemList + BreadcrumbList (+ FAQPage) JSON-LD.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import MovieCard from '../components/MovieCard.astro';
import Faq from '../components/Faq.astro';
import AdSlot from '../components/AdSlot.astro';
import RelatedLists from '../components/RelatedLists.astro';
import type { RankedList } from '../lib/lists';
import { allMovies, heroBackdrop } from '../lib/movies';
import { isMember, relatedLists } from '../lib/lists';
import { breadcrumbList, itemList, faqPage, type Crumb } from '../lib/jsonld';
import type { Dimension } from '../lib/taxonomy';

export interface Props {
  list: RankedList;
  /** Label for the dimension breadcrumb, e.g. "Genre". */
  dimensionLabel: string;
  intro?: string;
  perMovieBlurb?: Record<string, string>;
  faq?: { q: string; a: string }[];
}

const { list, dimensionLabel, intro, perMovieBlurb = {}, faq = [] } = Astro.props;
const site = Astro.site ?? new URL('https://topmostmovies.com');

// Related lists for internal linking (computed from the full movie set + this list's members).
const everyMovie = await allMovies();
const members = everyMovie.filter((m) => isMember(m, list.dimension, list.value));
const related = relatedLists(everyMovie, list.dimension, list.value, members);

const dimensionPathBase: Record<Dimension, string> = {
  industry: 'industry',
  country: 'country',
  language: 'language',
  genre: 'genre',
  year: 'year',
  decade: 'decade',
};

const listPath = `/${dimensionPathBase[list.dimension]}/${list.value}`;
const hubPath = `/${dimensionPathBase[list.dimension]}`;
const crumbs: Crumb[] = [
  { name: 'Home', path: '/' },
  { name: dimensionLabel, path: hubPath }, // dimension crumb → hub/index page
  { name: list.name, path: listPath },
];

const movieItems = list.movies.map((m) => ({ name: `${m.title} (${m.year})`, path: `/movie/${m.slug}` }));

const jsonLd: Record<string, unknown>[] = [
  breadcrumbList(crumbs, site),
  itemList(list.title, movieItems, site),
];
if (faq.length) jsonLd.push(faqPage(faq));

const description =
  intro?.slice(0, 160) ??
  `${list.title}: our ranked picks with ratings and age/parental info.`;

const seo = {
  title: `${list.title} — topmostmovies.com`,
  description,
  ogType: 'article' as const,
  image: list.movies[0]?.backdropUrl ?? list.movies[0]?.posterUrl,
  jsonLd,
};

const heroImg = heroBackdrop(list.movies.find((m) => m.backdropUrl)?.backdropUrl);
---

<BaseLayout seo={seo}>
  {/* Cinematic hero */}
  <section class="relative isolate overflow-hidden border-b border-ink-700/60">
    {
      heroImg && (
        <div class="absolute inset-0 -z-10" aria-hidden="true">
          <img
            src={heroImg}
            alt=""
            width="780"
            height="439"
            class="h-full w-full object-cover object-top opacity-30"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/80 to-ink-950/40" />
        </div>
      )
    }
    <div class="container-page py-10 sm:py-14">
      <Breadcrumbs crumbs={crumbs.slice(0, 2)} />
      <h1 class="mt-4 max-w-3xl text-3xl font-extrabold tracking-tight sm:text-5xl">
        {list.title}
      </h1>
      {
        intro && (
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-fg-muted sm:text-lg">
            {intro}
          </p>
        )
      }
      <p class="mt-4 text-sm text-fg-subtle">
        {list.total} {list.total === 1 ? 'movie' : 'movies'} · ranked by rating
      </p>
    </div>
  </section>

  <div class="container-page py-8">
    <AdSlot slot="list-top" class="mb-8" />

    {/* Visually-hidden heading keeps a logical h1 → h2 → h3 order for the ranked grid. */}
    <h2 class="sr-only">Ranked movies</h2>

    {
      list.movies.length === 0 ? (
        <p class="text-fg-muted">No movies in this list yet.</p>
      ) : (
        <ol class="grid grid-cols-2 gap-x-4 gap-y-7 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6">
          {list.movies.map((movie, i) => (
            <li>
              <MovieCard
                movie={movie}
                rank={i + 1}
                blurb={perMovieBlurb[movie.slug]}
                priority={i < 6}
              />
            </li>
          ))}
        </ol>
      )
    }

    {faq.length > 0 && <Faq items={faq} />}

    <RelatedLists links={related} />

    <AdSlot slot="list-bottom" class="mt-10" />
  </div>
</BaseLayout>
