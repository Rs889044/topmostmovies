---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Page not found — topmostmovies.com',
  description: 'The page you were looking for could not be found.',
  noindex: true,
};
---

<BaseLayout seo={seo}>
  <div class="container-page py-24 text-center">
    <p class="text-sm font-bold uppercase tracking-widest text-accent-400">404</p>
    <h1 class="mt-2 text-4xl font-extrabold tracking-tight">Page not found</h1>
    <p class="mx-auto mt-3 max-w-prose text-fg-muted">
      We couldn't find that page. It may have moved, or never existed.
    </p>
    <a
      href="/"
      class="mt-7 inline-block rounded-lg bg-accent-500 px-5 py-2.5 font-semibold text-ink-950 transition hover:bg-accent-400"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
