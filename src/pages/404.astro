---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Page not found — topmostmovies.com',
  description: 'The page you were looking for could not be found.',
  noindex: true,
};
---

<BaseLayout seo={seo}>
  <div class="py-12 text-center">
    <p class="text-sm font-semibold text-brand-500">404</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">Page not found</h1>
    <p class="mx-auto mt-3 max-w-prose text-gray-600">
      We couldn't find that page. It may have moved, or never existed.
    </p>
    <a
      href="/"
      class="mt-6 inline-block rounded-md bg-brand-500 px-4 py-2 text-sm font-medium text-white hover:bg-brand-700"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
