---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { breadcrumbList } from '../lib/jsonld';

const site = Astro.site ?? new URL('https://topmostmovies.com');
const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about' },
];

const seo = {
  title: 'About — topmostmovies.com',
  description: 'What topmostmovies.com is, how we curate Top 10 lists, and where our movie data comes from.',
  // Placeholder copy ships noindex until real content lands in Phase 6.
  noindex: true,
  jsonLd: breadcrumbList(crumbs, site),
};
---

<BaseLayout seo={seo}>
  <div class="container-page py-10">
    <Breadcrumbs crumbs={crumbs} />
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl">About</h1>
    <div class="mt-4 max-w-prose space-y-4 leading-relaxed text-fg-muted">
      <p>
        <em>Placeholder — real copy lands in Phase 6.</em> topmostmovies.com publishes
        curated Top 10 movie lists across industries, countries, languages, genres, years and
        decades, with honest age ratings and parental info.
      </p>
      <p>
        Movie data and images come from The Movie Database (TMDb); IMDb ratings are sourced
        via the OMDb API.
      </p>
    </div>
  </div>
</BaseLayout>
