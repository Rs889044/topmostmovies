---
import HubLayout from '../../layouts/HubLayout.astro';
import { hubEntries } from '../../lib/lists';

const entries = await hubEntries('decade');
---

<HubLayout
  title="Browse Movies by Decade"
  basePath="/decade"
  label="Decades"
  intro="Travel through film history decade by decade — from classics to modern hits. Each decade opens a curated Top 10 with honest ratings and age information."
  entries={entries}
/>
