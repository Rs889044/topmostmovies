---
import BaseLayout from '../layouts/BaseLayout.astro';
import { website, organization } from '../lib/jsonld';

const site = Astro.site ?? new URL('https://topmostmovies.com');

// Entry points to every list dimension (targets firmed up in Phase 3).
const dimensions = [
  { label: 'By Industry', href: '/industry/hollywood', note: 'Hollywood, Bollywood & more' },
  { label: 'By Country', href: '/country/south-korea', note: 'South Korea, Japan, France…' },
  { label: 'By Language', href: '/language/korean', note: 'Korean, Hindi, Spanish…' },
  { label: 'By Genre', href: '/genre/romance', note: 'Romance, Thriller, K-Drama…' },
  { label: 'By Year', href: '/year/2026', note: 'The best of each year' },
  { label: 'By Decade', href: '/decade/2010s', note: '1980s, 1990s, 2010s…' },
];

const seo = {
  title: 'Top 10 Movie Lists by Genre, Country, Language & Year — topmostmovies.com',
  description:
    'Curated Top 10 movie lists sliced by industry, country, language, genre, year and decade — with honest age ratings and parental info for every film.',
  ogType: 'website' as const,
  jsonLd: [website(site), organization(site)],
};
---

<BaseLayout seo={seo}>
  <section class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
      Top 10 movies, sliced every way that matters
    </h1>
    <p class="mt-3 max-w-prose text-gray-600">
      Hand-curated Top 10 lists across industries, countries, languages, genres, years and
      decades — each with honest age ratings and parental info so you always know what
      you're pressing play on. (Lists are being built out; this is the foundation.)
    </p>
  </section>

  <section aria-labelledby="browse">
    <h2 id="browse" class="mb-4 text-xl font-semibold">Browse by…</h2>
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        dimensions.map((d) => (
          <li>
            <a
              href={d.href}
              class="block rounded-lg border border-gray-200 p-4 transition hover:border-brand-500 hover:shadow-sm"
            >
              <span class="font-medium text-gray-900">{d.label}</span>
              <span class="mt-1 block text-sm text-gray-500">{d.note}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
