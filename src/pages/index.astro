---
import BaseLayout from '../layouts/BaseLayout.astro';
import { website, organization } from '../lib/jsonld';
import { allMovies } from '../lib/movies';
import { buildList, enumerateLists } from '../lib/lists';
import type { Dimension } from '../lib/taxonomy';

const site = Astro.site ?? new URL('https://topmostmovies.com');

const movies = await allMovies();
const refs = await enumerateLists();

// Group real (populated) lists by dimension, with a member count + best-rated count.
const DIMENSION_ORDER: { dimension: Dimension; label: string }[] = [
  { dimension: 'genre', label: 'By Genre' },
  { dimension: 'country', label: 'By Country' },
  { dimension: 'language', label: 'By Language' },
  { dimension: 'industry', label: 'By Industry' },
  { dimension: 'year', label: 'By Year' },
  { dimension: 'decade', label: 'By Decade' },
];

const pathBase: Record<Dimension, string> = {
  industry: 'industry',
  country: 'country',
  language: 'language',
  genre: 'genre',
  year: 'year',
  decade: 'decade',
};

const groups = DIMENSION_ORDER.map(({ dimension, label }) => {
  const items = refs
    .filter((r) => r.dimension === dimension)
    .map((r) => ({
      ...r,
      count: buildList(movies, dimension, r.value).total,
    }))
    .sort((a, b) => b.count - a.count);
  return { dimension, label, items };
}).filter((g) => g.items.length > 0);

const seo = {
  title: 'Top 10 Movie Lists by Genre, Country, Language & Year — topmostmovies.com',
  description:
    'Curated Top 10 movie lists sliced by industry, country, language, genre, year and decade — with honest age ratings and parental info for every film.',
  ogType: 'website' as const,
  jsonLd: [website(site), organization(site)],
};
---

<BaseLayout seo={seo}>
  <section class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
      Top 10 movies, sliced every way that matters
    </h1>
    <p class="mt-3 max-w-prose text-gray-600">
      Hand-curated Top 10 lists across industries, countries, languages, genres, years and
      decades — each with honest age ratings and parental info so you always know what
      you're pressing play on.
    </p>
  </section>

  {
    groups.map((group) => (
      <section aria-labelledby={`dim-${group.dimension}`} class="mb-10">
        <h2 id={`dim-${group.dimension}`} class="mb-4 text-xl font-semibold">
          {group.label}
        </h2>
        <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {group.items.map((item) => (
            <li>
              <a
                href={`/${pathBase[group.dimension]}/${item.value}`}
                class="flex items-center justify-between rounded-lg border border-gray-200 p-3 transition hover:border-brand-500 hover:shadow-sm"
              >
                <span class="font-medium text-gray-900">{item.name}</span>
                <span class="text-sm text-gray-400">{item.count}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</BaseLayout>
