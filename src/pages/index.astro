---
import BaseLayout from '../layouts/BaseLayout.astro';
import MovieRow from '../components/MovieRow.astro';
import { website, organization } from '../lib/jsonld';
import { allMovies, heroBackdrop } from '../lib/movies';
import { buildList, enumerateLists, enumerateCombos, liveValueSet } from '../lib/lists';
import type { Dimension } from '../lib/taxonomy';

const site = Astro.site ?? new URL('https://topmostmovies.com');
const movies = await allMovies();
const refs = await enumerateLists();

// Popular long-tail combos (genre×language) to surface + internally link from the homepage.
const combos = (await enumerateCombos()).slice(0, 18);

// Curated featured rows (flagship lists from KEYWORDS.md priorities).
const FEATURED: { dimension: Dimension; value: string; title: string }[] = [
  { dimension: 'language', value: 'korean', title: 'Top Korean Movies' },
  { dimension: 'genre', value: 'thriller', title: 'Top Thriller Movies' },
  { dimension: 'genre', value: 'romance', title: 'Top Romance Movies' },
  { dimension: 'industry', value: 'bollywood', title: 'Top Bollywood Movies' },
  { dimension: 'genre', value: 'horror', title: 'Top Horror Movies' },
  { dimension: 'genre', value: 'animation', title: 'Top Animated Movies' },
];

const pathBase: Record<Dimension, string> = {
  industry: 'industry', country: 'country', language: 'language',
  genre: 'genre', studio: 'studio', theme: 'theme', year: 'year', decade: 'decade',
};

const featuredRows = FEATURED.map((f) => {
  const list = buildList(movies, f.dimension, f.value, undefined, 12);
  return { ...f, href: `/${pathBase[f.dimension]}/${f.value}`, movies: list.movies };
}).filter((r) => r.movies.length >= 4);

// Browse-by-dimension groups (populated values only, most-populated first).
const DIMENSION_ORDER: { dimension: Dimension; label: string }[] = [
  { dimension: 'genre', label: 'Genres' },
  { dimension: 'theme', label: 'Themes' },
  { dimension: 'studio', label: 'Studios' },
  { dimension: 'country', label: 'Countries' },
  { dimension: 'language', label: 'Languages' },
  { dimension: 'decade', label: 'Decades' },
];
// Only link to lists that are actually generated (live set) — prevents links to thin
// studio/theme values that don't get a page.
const live = await liveValueSet();
const groups = DIMENSION_ORDER.map(({ dimension, label }) => {
  const items = refs
    .filter((r) => r.dimension === dimension && live.has(`${r.dimension}:${r.value}`))
    .map((r) => ({ ...r, count: buildList(movies, dimension, r.value).total }))
    .sort((a, b) => b.count - a.count);
  return { dimension, label, items };
}).filter((g) => g.items.length > 0);

// A backdrop for the hero (a popular, well-rated title).
const heroMovie = [...movies]
  .filter((m) => m.backdropUrl)
  .sort((a, b) => (b.popularity ?? 0) - (a.popularity ?? 0))[0];

const seo = {
  title: 'Top 10 Movie Lists by Genre, Country, Language & Year — topmostmovies.com',
  description:
    'Curated Top 10 movie lists sliced by industry, country, language, genre, year and decade — with honest age ratings and parental info for every film.',
  ogType: 'website' as const,
  image: heroMovie?.backdropUrl,
  jsonLd: [website(site), organization(site)],
};
---

<BaseLayout seo={seo}>
  {/* Hero */}
  <section class="relative isolate overflow-hidden border-b border-ink-700/60">
    {
      heroMovie?.backdropUrl && (
        <div class="absolute inset-0 -z-10" aria-hidden="true">
          <img src={heroBackdrop(heroMovie.backdropUrl)} alt="" width="780" height="439" fetchpriority="high" class="h-full w-full object-cover object-top opacity-30" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/85 to-ink-950/60" />
        </div>
      )
    }
    <div class="container-page pb-12 pt-14 sm:pb-14 sm:pt-20">
      <p class="text-sm font-semibold uppercase tracking-widest text-accent-400">
        Curated movie discovery
      </p>
      <h1 class="mt-3 max-w-3xl text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl">
        Top 10 movies, sliced every way that matters
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-fg-muted">
        Hand-curated Top 10 lists across industries, countries, languages, genres, years and
        decades — each with honest age ratings and parental info, so you always know what
        you're pressing play on.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/best-movies" class="rounded-lg bg-accent-500 px-5 py-2.5 font-semibold text-ink-950 transition hover:bg-accent-400">
          Greatest of all time
        </a>
        <a href="/popular" class="rounded-lg border border-ink-600 px-5 py-2.5 font-semibold text-fg transition hover:bg-ink-800">
          Most popular
        </a>
      </div>
      {/* Quick picks — links to the highest-intent destination pages. */}
      <nav aria-label="Quick picks" class="mt-6 flex flex-wrap gap-2">
        {
          [
            { label: 'Best movies ever', href: '/best-movies' },
            { label: 'Most watched', href: '/popular' },
            { label: 'Thrillers', href: '/genre/thriller' },
            { label: 'Korean', href: '/language/korean' },
            { label: 'Bollywood', href: '/industry/bollywood' },
            { label: 'Mature / R-rated', href: '/mature' },
          ].map((p) => (
            <a
              href={p.href}
              class="rounded-full border border-ink-600 bg-ink-900/60 px-4 py-1.5 text-sm font-medium text-fg-muted backdrop-blur-sm transition-colors hover:border-accent-500/60 hover:text-fg"
            >
              {p.label}
            </a>
          ))
        }
      </nav>
    </div>
  </section>

  {/* Curated rows */}
  {featuredRows.map((row) => <MovieRow title={row.title} href={row.href} movies={row.movies} />)}

  {/* Browse by dimension */}
  <div class="container-page mt-16">
    {
      groups.map((group) => (
        <section aria-labelledby={`dim-${group.dimension}`} class="mb-10">
          <h2 id={`dim-${group.dimension}`} class="mb-4 text-2xl font-bold">{group.label}</h2>
          <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
            {group.items.map((item) => (
              <li>
                <a
                  href={`/${pathBase[group.dimension]}/${item.value}`}
                  class="flex items-center justify-between rounded-xl border border-ink-700/60 bg-ink-900 px-4 py-3 transition hover:border-accent-500/60 hover:bg-ink-800"
                >
                  <span class="font-medium text-fg">{item.name}</span>
                  <span class="text-sm text-fg-subtle">{item.count}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }

    {/* Popular long-tail combos — the site's differentiator + internal links to /best/* */}
    {
      combos.length > 0 && (
        <section aria-labelledby="combos" class="mb-10">
          <h2 id="combos" class="mb-1 text-2xl font-bold">Popular combinations</h2>
          <p class="mb-4 text-sm text-fg-subtle">
            The specific lists other sites don't make — by language and genre.
          </p>
          <ul class="flex flex-wrap gap-2">
            {combos.map((c) => (
              <li>
                <a
                  href={`/best/${c.primaryValue}-${c.genre}`}
                  class="inline-flex items-center gap-1.5 rounded-full border border-ink-600 bg-ink-800 px-3.5 py-1.5 text-sm text-fg-muted transition-colors hover:border-accent-500/60 hover:text-fg"
                >
                  Best {c.primaryName} {c.genreName}
                  <span class="text-fg-subtle">{c.count}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>
</BaseLayout>
