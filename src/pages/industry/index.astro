---
import HubLayout from '../../layouts/HubLayout.astro';
import { hubEntries } from '../../lib/lists';

const entries = await hubEntries('industry');
---

<HubLayout
  title="Browse Movies by Industry"
  basePath="/industry"
  label="Industries"
  intro="Explore the world's great film industries — Hollywood and Bollywood — each with a curated Top 10 of essential watches, honest ratings and age information."
  entries={entries}
/>
