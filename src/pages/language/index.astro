---
import HubLayout from '../../layouts/HubLayout.astro';
import { hubEntries } from '../../lib/lists';

const entries = await hubEntries('language');
---

<HubLayout
  title="Browse Movies by Language"
  basePath="/language"
  label="Languages"
  intro="Discover great cinema by language — Korean, Hindi, Japanese, Spanish, French and English. Each language opens a curated Top 10 with honest ratings and age info."
  entries={entries}
/>
