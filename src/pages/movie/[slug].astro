---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AdSlot from '../../components/AdSlot.astro';
import { allMovies } from '../../lib/movies';
import { featuredIn } from '../../lib/lists';
import { breadcrumbList, movie as movieJsonLd, type Crumb } from '../../lib/jsonld';
import { nameForSlug } from '../../lib/taxonomy';

export async function getStaticPaths() {
  const movies = await allMovies();
  return movies.map((m) => ({ params: { slug: m.slug }, props: { movie: m } }));
}

const { movie } = Astro.props;
const site = Astro.site ?? new URL('https://topmostmovies.com');

const lists = featuredIn(movie);
const genreNames = movie.genres
  .map((g) => nameForSlug('genre', g))
  .filter((n): n is string => Boolean(n));

const crumbs: Crumb[] = [
  { name: 'Home', path: '/' },
  { name: movie.title, path: `/movie/${movie.slug}` },
];

const jsonLd: Record<string, unknown>[] = [
  breadcrumbList(crumbs, site),
  movieJsonLd(
    {
      name: movie.title,
      path: `/movie/${movie.slug}`,
      image: movie.posterUrl,
      // Use ORIGINAL synopsis when written; never the raw TMDb overview in structured data.
      description: movie.synopsis,
      year: movie.year,
      genres: genreNames,
      // Only emit ratings/contentRating when real values exist (honesty rule).
      rating: movie.imdbRating ?? movie.tmdbRating,
      ratingCount: movie.tmdbVotes,
      contentRating: movie.certification,
    },
    site,
  ),
];

const seo = {
  title: `${movie.title} (${movie.year}) — Rating, Age Certification & Where It's Featured`,
  description:
    movie.synopsis?.slice(0, 160) ??
    `${movie.title} (${movie.year}): rating, official age certification and parental info, plus every Top 10 list it's featured in.`,
  ogType: 'video.movie' as const,
  image: movie.backdropUrl ?? movie.posterUrl,
  jsonLd,
};
---

<BaseLayout seo={seo}>
  <Breadcrumbs crumbs={crumbs} />

  <article class="mt-4 grid grid-cols-1 gap-6 sm:grid-cols-[200px_1fr]">
    <div>
      {
        movie.posterUrl ? (
          <Image
            src={movie.posterUrl}
            alt={movie.posterAlt}
            width={200}
            height={300}
            class="w-full rounded-lg bg-gray-100 object-cover"
          />
        ) : (
          <div class="flex aspect-[2/3] w-full items-center justify-center rounded-lg bg-gray-100 text-sm text-gray-400">
            No poster
          </div>
        )
      }
    </div>

    <div>
      <h1 class="text-3xl font-bold tracking-tight">
        {movie.title} <span class="font-normal text-gray-400">({movie.year})</span>
      </h1>
      {
        movie.originalTitle && (
          <p class="mt-1 text-gray-500">Original title: {movie.originalTitle}</p>
        )
      }

      {/* Ratings */}
      <div class="mt-4 flex flex-wrap gap-4 text-sm">
        {
          movie.imdbRating !== undefined && (
            <span class="rounded bg-gray-50 px-3 py-1">
              <strong>IMDb</strong> {movie.imdbRating.toFixed(1)}/10
            </span>
          )
        }
        {
          movie.tmdbRating !== undefined && (
            <span class="rounded bg-gray-50 px-3 py-1">
              <strong>TMDb</strong> {movie.tmdbRating.toFixed(1)}/10
            </span>
          )
        }
      </div>

      {/* Parental / age — HONEST. Never fabricate; show "data unavailable" when missing. */}
      <section class="mt-5" aria-labelledby="age-heading">
        <h2 id="age-heading" class="text-lg font-semibold">Age & parental info</h2>
        <p class="mt-1 text-gray-700">
          {
            movie.certification ? (
              <>
                Official certification:{' '}
                <strong>{movie.certification}</strong>
                <span class="text-gray-500">
                  {' '}
                  ({movie.certificationCountry ?? 'unknown'} rating system)
                </span>
              </>
            ) : (
              <span class="text-gray-500">Not rated / data unavailable.</span>
            )
          }
        </p>
        {
          movie.parentalNotes && (
            <p class="mt-2 max-w-prose text-gray-600">{movie.parentalNotes}</p>
          )
        }
      </section>

      {/* Synopsis — ORIGINAL only. TMDb overview is never published verbatim. */}
      <section class="mt-5" aria-labelledby="synopsis-heading">
        <h2 id="synopsis-heading" class="text-lg font-semibold">Synopsis</h2>
        {
          movie.synopsis ? (
            <p class="mt-1 max-w-prose text-gray-700">{movie.synopsis}</p>
          ) : (
            <p class="mt-1 max-w-prose text-sm text-gray-400">
              <em>Original synopsis coming soon (Phase 5).</em>
            </p>
          )
        }
      </section>
    </div>
  </article>

  <AdSlot slot="movie-inline" class="my-8" />

  {/* Featured in — internal linking powerhouse */}
  {
    lists.length > 0 && (
      <section aria-labelledby="featured-heading" class="mt-8">
        <h2 id="featured-heading" class="mb-3 text-xl font-semibold">Featured in</h2>
        <ul class="flex flex-wrap gap-2">
          {lists.map((l) => (
            <li>
              <a
                href={l.path}
                class="inline-block rounded-full border border-gray-200 px-3 py-1 text-sm text-gray-700 hover:border-brand-500 hover:text-brand-700"
              >
                {l.name}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
