---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AdSlot from '../../components/AdSlot.astro';
import { allMovies, heroBackdrop } from '../../lib/movies';
import { featuredIn } from '../../lib/lists';
import { breadcrumbList, movie as movieJsonLd, type Crumb } from '../../lib/jsonld';
import { nameForSlug } from '../../lib/taxonomy';

export async function getStaticPaths() {
  const movies = await allMovies();
  return movies.map((m) => ({ params: { slug: m.slug }, props: { movie: m } }));
}

const { movie } = Astro.props;
const site = Astro.site ?? new URL('https://topmostmovies.com');

const lists = featuredIn(movie);
const genreNames = movie.genres
  .map((g) => nameForSlug('genre', g))
  .filter((n): n is string => Boolean(n));

const crumbs: Crumb[] = [
  { name: 'Home', path: '/' },
  { name: movie.title, path: `/movie/${movie.slug}` },
];

const jsonLd: Record<string, unknown>[] = [
  breadcrumbList(crumbs, site),
  movieJsonLd(
    {
      name: movie.title,
      path: `/movie/${movie.slug}`,
      image: movie.posterUrl,
      // Use ORIGINAL synopsis when written; never the raw TMDb overview in structured data.
      description: movie.synopsis,
      year: movie.year,
      genres: genreNames,
      // Only emit ratings/contentRating when real values exist (honesty rule).
      rating: movie.imdbRating ?? movie.tmdbRating,
      ratingCount: movie.tmdbVotes,
      contentRating: movie.certification,
    },
    site,
  ),
];

const seo = {
  title: `${movie.title} (${movie.year}) — Rating, Age Certification & Where It's Featured`,
  description:
    movie.synopsis?.slice(0, 160) ??
    `${movie.title} (${movie.year}): rating, official age certification and parental info, plus every Top 10 list it's featured in.`,
  ogType: 'video.movie' as const,
  image: movie.backdropUrl ?? movie.posterUrl,
  jsonLd,
};
---

<BaseLayout seo={seo}>
  {/* Cinematic backdrop hero */}
  <section class="relative isolate border-b border-ink-700/60">
    {
      movie.backdropUrl && (
        <div class="absolute inset-0 -z-10" aria-hidden="true">
          <img
            src={heroBackdrop(movie.backdropUrl)}
            alt=""
            width="780"
            height="439"
            fetchpriority="high"
            class="h-full w-full object-cover object-top opacity-25"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/85 to-ink-950/50" />
        </div>
      )
    }

    <div class="container-page py-8 sm:py-12">
      <Breadcrumbs crumbs={crumbs} />

      <article class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-[220px_1fr] sm:gap-8">
        <div class="mx-auto w-40 shrink-0 sm:mx-0 sm:w-full">
          {
            movie.posterUrl ? (
              <Image
                src={movie.posterUrl}
                alt={movie.posterAlt}
                width={300}
                height={450}
                loading="eager"
                class="w-full rounded-xl bg-ink-800 object-cover shadow-2xl ring-1 ring-ink-700/60"
              />
            ) : (
              <div class="flex aspect-[2/3] w-full items-center justify-center rounded-xl bg-ink-800 text-sm text-fg-subtle">
                No poster
              </div>
            )
          }
        </div>

        <div>
          <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
            {movie.title} <span class="font-medium text-fg-subtle">({movie.year})</span>
          </h1>
          {
            movie.originalTitle && (
              <p class="mt-1 text-fg-muted">Original title: {movie.originalTitle}</p>
            )
          }

          {/* Ratings + cert chips */}
          <div class="mt-4 flex flex-wrap items-center gap-2.5 text-sm">
            {
              movie.imdbRating !== undefined && (
                <span class="inline-flex items-center gap-1.5 rounded-lg bg-ink-800 px-3 py-1.5 ring-1 ring-ink-700/60">
                  <span class="text-star" aria-hidden="true">★</span>
                  <strong>{movie.imdbRating.toFixed(1)}</strong>
                  <span class="text-fg-subtle">IMDb</span>
                </span>
              )
            }
            {
              movie.tmdbRating !== undefined && (
                <span class="inline-flex items-center gap-1.5 rounded-lg bg-ink-800 px-3 py-1.5 ring-1 ring-ink-700/60">
                  <strong>{movie.tmdbRating.toFixed(1)}</strong>
                  <span class="text-fg-subtle">TMDb</span>
                </span>
              )
            }
            {
              movie.certification && (
                <span class="rounded-lg border border-ink-600 px-3 py-1.5 text-fg-muted">
                  {movie.certification}
                </span>
              )
            }
          </div>

          {/* Genre tags */}
          {
            genreNames.length > 0 && (
              <ul class="mt-4 flex flex-wrap gap-2">
                {movie.genres.map((g) => {
                  const name = nameForSlug('genre', g);
                  return name ? (
                    <li>
                      <a
                        href={`/genre/${g}`}
                        class="rounded-full bg-ink-800 px-3 py-1 text-xs text-fg-muted ring-1 ring-ink-700/60 hover:text-accent-400"
                      >
                        {name}
                      </a>
                    </li>
                  ) : null;
                })}
              </ul>
            )
          }

          {/* Synopsis — ORIGINAL only (never TMDb overview verbatim). */}
          {
            movie.synopsis && (
              <section class="mt-6" aria-labelledby="synopsis-heading">
                <h2 id="synopsis-heading" class="text-lg font-bold">Synopsis</h2>
                <p class="mt-2 max-w-prose leading-relaxed text-fg-muted">{movie.synopsis}</p>
              </section>
            )
          }

          {/* Parental / age — HONEST. Never fabricate; "data unavailable" when missing. */}
          <section
            class="mt-6 rounded-xl border border-ink-700/60 bg-ink-900/60 p-5"
            aria-labelledby="age-heading"
          >
            <h2 id="age-heading" class="text-lg font-bold">Age &amp; parental info</h2>
            <p class="mt-2 text-fg-muted">
              {
                movie.certification ? (
                  <>
                    Official certification:{' '}
                    <strong class="text-fg">{movie.certification}</strong>
                    <span class="text-fg-subtle">
                      {' '}({movie.certificationCountry ?? 'unknown'} rating system)
                    </span>
                  </>
                ) : (
                  <span class="text-fg-subtle">Not rated / data unavailable.</span>
                )
              }
            </p>
            {
              movie.parentalNotes && (
                <p class="mt-2 max-w-prose text-fg-muted">{movie.parentalNotes}</p>
              )
            }
          </section>
        </div>
      </article>
    </div>
  </section>

  <div class="container-page py-8">
    <AdSlot slot="movie-inline" class="mb-8" />

    {/* Featured in — internal linking powerhouse */}
    {
      lists.length > 0 && (
        <section aria-labelledby="featured-heading">
          <h2 id="featured-heading" class="mb-4 text-2xl font-bold">Featured in</h2>
          <ul class="flex flex-wrap gap-2">
            {lists.map((l) => (
              <li>
                <a
                  href={l.path}
                  class="inline-flex items-center rounded-full border border-ink-600 bg-ink-800 px-3.5 py-1.5 text-sm text-fg-muted transition-colors hover:border-accent-500/60 hover:text-fg"
                >
                  {l.name}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>
</BaseLayout>
