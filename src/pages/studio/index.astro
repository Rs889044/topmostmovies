---
import HubLayout from '../../layouts/HubLayout.astro';
import { hubEntries } from '../../lib/lists';

const entries = await hubEntries('studio');
---

<HubLayout
  title="Browse Movies by Studio"
  basePath="/studio"
  label="Studios"
  intro="Explore the best films from the studios behind them — Pixar, Studio Ghibli, Marvel, A24 and more. Each studio opens a curated Top 10 with honest ratings and age info."
  entries={entries}
/>
